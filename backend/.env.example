# Scam Detector Backend Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# VirusTotal API (Optional - for real domain reputation checking)
# Get your API key from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# CORS Configuration
CORS_ORIGIN=*

# Logging
LOG_LEVEL=debug
